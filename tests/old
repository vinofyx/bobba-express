import { test, expect } from '@playwright/test';

test.describe('BobbaExpress Authentication', () => {
  test('Admin login functionality', async ({ page }) => {
    // Navigate to login page
    await page.goto('/login');
    
    // Verify login page loads
    await expect(page).toHaveTitle(/BobbaExpress/);
    await expect(page.locator('h1')).toContainText('Login');
    
    // Fill login form
    await page.fill('input[name="email"]', 'admin@bobba.com');
    await page.fill('input[name="password"]', 'Admin@1234');
    
    // Submit login
    await page.click('button[type="submit"]');
    
    // Verify successful login - redirect to dashboard
    await page.waitForURL('/dashboard');
    await expect(page.locator('h1')).toContainText('Dashboard');
    
    // Verify user info displayed
    await expect(page.locator('.user-info')).toContainText('Admin');
  });

  test('Agent login functionality', async ({ page }) => {
    await page.goto('/login');
    
    await page.fill('input[name="email"]', 'agent@bobba.com');
    await page.fill('input[name="password"]', 'Agent@1234');
    await page.click('button[type="submit"]');
    
    await page.waitForURL('/agent/dashboard');
    await expect(page.locator('h1')).toContainText('Agent Dashboard');
  });

  test('Customer login functionality', async ({ page }) => {
    await page.goto('/login');
    
    await page.fill('input[name="email"]', 'customer@bobba.com');
    await page.fill('input[name="password"]', 'Customer@1234');
    await page.click('button[type="submit"]');
    
    await page.waitForURL('/customer/dashboard');
    await expect(page.locator('h1')).toContainText('Customer Dashboard');
  });

  test('Invalid login credentials', async ({ page }) => {
    await page.goto('/login');
    
    // Try invalid credentials
    await page.fill('input[name="email"]', 'invalid@example.com');
    await page.fill('input[name="password"]', 'wrongpassword');
    await page.click('button[type="submit"]');
    
    // Verify error message
    await expect(page.locator('.error-message')).toBeVisible();
    await expect(page.locator('.error-message')).toContainText('Invalid credentials');
    
    // Verify still on login page
    await expect(page).toHaveURL(/.*login/);
  });

  test('Empty form validation', async ({ page }) => {
    await page.goto('/login');
    
    // Try to submit empty form
    await page.click('button[type="submit"]');
    
    // Verify validation errors
    await expect(page.locator('.error-message')).toBeVisible();
    await expect(page.locator('.error-message')).toContainText('Email is required');
  });

  test('Logout functionality', async ({ page }) => {
    // Login first
    await page.goto('/login');
    await page.fill('input[name="email"]', 'admin@bobba.com');
    await page.fill('input[name="password"]', 'Admin@1234');
    await page.click('button[type="submit"]');
    
    await page.waitForURL('/dashboard');
    
    // Logout
    await page.click('button:has-text("Logout")');
    
    // Verify redirected to login page
    await expect(page).toHaveURL('/login');
  });
});
