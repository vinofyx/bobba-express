		{
			"name": "Tracking",
			"item": [
				{
					"name": "GET /tracking/{{PARCEL_1}}",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status 200\", () => pm.response.to.have.status(200));",
									"pm.test(\"Timeline has 3 steps\", () => pm.expect(pm.response.json().timeline.length).to.be.gte(3));",
									"pm.test(\"In Transit\", () => pm.expect(pm.response.json().currentStatus).to.eql(\"in_transit\"));",
									"pm.test(\"ETA present\", () => pm.expect(pm.response.json().eta).to.exist);"
								],
								"type": "text/javascript"
							}
						}
					],
