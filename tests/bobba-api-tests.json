{
	"info": {
		"_postman_id": "bobba-express-api-tests",
		"name": "BobbaExpress API Tests",
		"description": "Complete API test suite for BobbaExpress application covering authentication, customer creation, pickup scheduling, shipment management, and tracking functionality.",
