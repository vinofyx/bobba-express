		{
			"name": "Parcel Management",
			"item": [
				{
					"name": "GET /parcels?pickupId={{PICKUP_ID}}",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status 200\", () => pm.response.to.have.status(200));",
									"pm.test(\"3 parcels created\", () => pm.expect(pm.response.json().data.length).to.eql(3));",
									"pm.environment.set(\"PARCEL_1\", pm.response.json().data[0].trackingNumber);",
									"pm.environment.set(\"PARCEL_2\", pm.response.json().data[1].trackingNumber);",
									"pm.environment.set(\"PARCEL_3\", pm.response.json().data[2].trackingNumber);"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{TOKEN}}"
							}
						],
						"url": {
							"raw": "{{BASE_URL}}/parcels?pickupId={{PICKUP_ID}}",
							"host": [
								"{{BASE_URL}}"
							],
							"path": [
								"parcels"
							],
							"query": [
								{
									"key": "pickupId",
									"value": "{{PICKUP_ID}}"
								}
							]
						}
					},
					"response": []
				}
			]
		},
