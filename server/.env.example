# BobbaExpress Server Environment Configuration
# Copy this file to .env and update the values

# Database Configuration
MONGODB_URI=your_mongodb_atlas_uri

# JWT Configuration (ALL THREE required — missing any one causes 500 on login)
JWT_SECRET=bobba_express_jwt_secret_dev_2025_change_in_prod
JWT_REFRESH_SECRET=bobba_express_refresh_secret_dev_2025_must_differ
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Server Configuration
NODE_ENV=production
PORT=5000

# Client Configuration (supports comma-separated for multiple origins)
CLIENT_URL=https://bobba-express-client-qa42.vercel.app

# SMS Configuration (Fast2SMS — India)
# 1. Sign up at https://www.fast2sms.com
# 2. Go to Dashboard → Dev API → copy your API Key
# 3. Paste it below (replace the empty value)
# Leave EMPTY to use dev/mock mode — SMS will be printed to console instead of sent
FAST2SMS_API_KEY=4r5C0N2iavIxzqkmhFQWURl1jBLw3A7gEypeODYSZounVTPMH6bxq35ZcYCJGtWeifFKRTB4AVmz7HsM

# Email Configuration (Optional)
# Leave empty to use mock mode (emails logged to console)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# File Upload Configuration
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=5242880

# Logging Configuration
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# Test Configuration
TEST_MODE=true
MOCK_SMS=true
MOCK_EMAIL=true

# Development Configuration
DEBUG=bobbaexpress:*
