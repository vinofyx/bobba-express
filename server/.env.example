# BobbaExpress Server Environment Variables

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/bobbaexpress

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# SMS Service (Fast2SMS - India)
# Get your API key from https://www.fast2sms.com/
FAST2SMS_API_KEY=your-fast2sms-api-key-here

# Server Configuration
NODE_ENV=development
PORT=5000

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:8080

# Optional: Log Level
LOG_LEVEL=info
