# BobbaExpress Server Environment Configuration
# Copy this file to .env and update the values

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/bobbaexpress

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# Server Configuration
NODE_ENV=development
PORT=5000
API_URL=http://localhost:5000

# Client Configuration
CLIENT_URL=http://localhost:8080

# SMS Configuration (Fast2SMS — India)
# 1. Sign up at https://www.fast2sms.com
# 2. Go to Dashboard → Dev API → copy your API Key
# 3. Paste it below (replace the empty value)
# Leave EMPTY to use dev/mock mode — SMS will be printed to console instead of sent
FAST2SMS_API_KEY=

# Email Configuration (Optional)
# Leave empty to use mock mode (emails logged to console)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# File Upload Configuration
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=5242880

# Logging Configuration
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# Test Configuration
TEST_MODE=true
MOCK_SMS=true
MOCK_EMAIL=true

# Development Configuration
DEBUG=bobbaexpress:*
