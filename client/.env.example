# Development API URL (local backend)
# Falls back to '/api' proxy in Vite config
VITE_API_BASE_URL=http://localhost:5000/api

# Production API URL — points to your deployed backend (Render)
# Set this SAME variable in your Vercel project dashboard:
#   Vercel → Project → Settings → Environment Variables
#   Name:  VITE_API_BASE_URL
#   Value: https://bobba-express-api.onrender.com/api
VITE_API_BASE_URL=https://bobba-express-api.onrender.com/api
