# Development API URL (local backend)
# Falls back to '/api' proxy in Vite config
VITE_API_BASE_URL=http://localhost:5000

# Production API URL — points to your deployed backend (NO /api suffix — paths include it)
# Set this SAME variable in your Vercel project dashboard:
#   Vercel → Project → Settings → Environment Variables
#   Name:  VITE_API_BASE_URL
#   Value: https://your-backend-url.vercel.app   ← NO /api at the end
#
# Leave EMPTY to use Vercel rewrites (client/vercel.json forwards /api/* to backend)
# VITE_API_BASE_URL=
